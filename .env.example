# Copy this file to ".env" in the same folder as package.json, then paste your key.
# Get a key: https://console.anthropic.com/settings/keys
#
# Local dev: restart `npm run dev` after changing this file.
# Vercel deploy: set ANTHROPIC_API_KEY in Project → Settings → Environment Variables (not only in .env).
#
# You can use either name (pick one):
ANTHROPIC_API_KEY=
# VITE_ANTHROPIC_API_KEY=
